# ────────────────────────────────────────────────────────────────────
# AI-Job-Scan — environment configuration
# Copy this file to  .env  and fill in the values you need.
# ────────────────────────────────────────────────────────────────────

# ── LLM (bring your own model & key) ─────────────────────────────────
# Pick ONE model in litellm's "provider/model" form. This one string
# drives BOTH the scraping-extraction and the evaluation/proposal steps.
LLM_MODEL=deepseek/deepseek-chat
# LLM_MODEL=gemini/gemini-2.0-flash
# LLM_MODEL=openai/gpt-4o-mini
# LLM_MODEL=anthropic/claude-sonnet-4-20250514
# LLM_MODEL=groq/llama-3.3-70b-versatile

# Set the API key that matches your chosen provider (leave the rest blank).
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=

# ── Job search (required) ────────────────────────────────────────────
# Serper.dev powers the Google search step. Free tier available.
# Get a key at https://serper.dev
SERPER_API_KEY=
